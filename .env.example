# Copy this file and set these values in your Vercel Project Dashboard:
# Vercel Dashboard → Project → Settings → Environment Variables

# Database (MUST be a cloud MySQL — localhost won't work on Vercel)
DB_HOST=your_cloud_mysql_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=debug_arena

# JWT (keep these consistent between local and production)
JWT_SECRET=debug_arena_secret_key_2024_cyberpunk
JWT_EXPIRES_IN=24h

# Optional: your frontend URL (for CORS)
FRONTEND_URL=https://vu-lnix2-0-debug-challenge.vercel.app

# Environment
NODE_ENV=production
